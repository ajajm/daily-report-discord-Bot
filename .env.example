# ============================================================
# DISCORD BOT CONFIGURATION
# ============================================================
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_GUILD_ID=your_guild_id_here

# ============================================================
# DATABASE
# ============================================================
# SQLite (default, no extra config needed)
DB_PATH=./data/reports.db

# PostgreSQL (optional upgrade path)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================================
# DASHBOARD SERVER
# ============================================================
DASHBOARD_PORT=3000
DASHBOARD_SECRET=your_super_secret_jwt_key_here
DASHBOARD_URL=http://localhost:3000

# ============================================================
# BOT DEFAULTS (can be overridden via commands)
# ============================================================
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_DEADLINE=21:00
DEFAULT_REMINDER_TIMES=18:00,19:30,20:30

# ============================================================
# ADMIN
# ============================================================
BOT_ADMIN_ROLE_NAME=Admin
MANAGER_ROLE_NAME=Manager

# ============================================================
# FEATURES
# ============================================================
ENABLE_DM_REMINDERS=true
ENABLE_WEEKLY_SUMMARY=true
ENABLE_SMART_REMINDERS=true
ENABLE_QUALITY_CHECK=true
LOG_LEVEL=info

# ============================================================
# ENVIRONMENT
# ============================================================
NODE_ENV=production
